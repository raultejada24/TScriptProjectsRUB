# (Tarea extra) RESPUESTA:
# 1. Dependencia: La velocidad actual depende de la frecuencia con la que el ordenador
#    es capaz de ejecutar la función onTimer (los FPS o cuadros por segundo).

# 2. Problema: En ordenadores potentes el juego irá demasiado rápido (acelerado),
#    mientras que en ordenadores antiguos irá en cámara lenta.

# 3. Solución: Implementar "Delta Time" (dt). Consiste en calcular el tiempo real
#    transcurrido entre el cuadro anterior y el actual, y multiplicar la velocidad
#    por ese tiempo (pos = pos + vel * dt) para independizar el movimiento del hardware.


# define global variables
var paddle_y_pos = canvas.height() - 50;
var paddle_x_pos = canvas.width() / 2;
var paddle_width = 150;
var ball_radius = 20;
var n_balls = 5;

# container to save the balls' attributes
class Ball {
public:
	var x;
	var y;
	var vel_x;
	var vel_y;
	var r;
	var g;
	var b;
	
	constructor() {
		x = math.random() * canvas.width();
		y = math.random() * canvas.height()/2;
		vel_x = math.random() * 2;
		vel_y = (math.random() - 0.5) * 3;
		r = 1 * math.random();
		g = 1 * math.random();
		b = 1 * math.random();
	}
}

# create balls and save them into an array
var ball_list = [];
for var i in 0:n_balls do {
	ball_list.push(Ball());	
}

# our main loop
function onTimer(event){
	# white background
	canvas.setFillColor(1, 1, 1);
	canvas.fillRect(0, 0, canvas.width(), canvas.height());

	# draw paddle
	var paddle_height = 20;
	canvas.setFillColor(1,0,0);
	canvas.fillRect(paddle_x_pos - paddle_width/2, paddle_y_pos, paddle_width, paddle_height);

	for var i in 0:n_balls do {
		var b = ball_list[i];
		# collision with paddle
        # AÑADIMOS: "and b.vel_y > 0"
        # Esto significa: "Solo rebota si la bola está bajando".
        # Si la bola está subiendo (vel_y negativo), ignora el choque para que pueda salir.
		if b.y > paddle_y_pos - ball_radius and b.x > paddle_x_pos - paddle_width/2 and b.x < paddle_x_pos + paddle_width/2 and b.vel_y > 0 then {
			b.vel_y *= -1;
		}

		# collision with left wall
		if b.x < ball_radius then {
			b.vel_x *= -1;
		}

		#collision with right wall
		if b.x > canvas.width() - ball_radius then {
			b.vel_x *= -1;
		}

		# move ball according to its velocity
		b.x += b.vel_x;
		b.y += b.vel_y;

		# add gravity
		b.vel_y += 0.1;

		# draw the ball!
		canvas.setFillColor(b.r, b.g, b.b);
		canvas.fillCircle(b.x, b.y, ball_radius);
	}
}

# move paddle according to horizontal mouse position
function onMouseMove(event) {
	paddle_x_pos = event.x;
}

# create new ball on mouse click
function onClick(event) {
	var b = Ball();
	ball_list.push(b);
	n_balls = n_balls + 1;
}



setEventHandler("timer", onTimer);
setEventHandler("canvas.mousedown", onClick);
setEventHandler("canvas.mousemove", onMouseMove);
enterEventMode();