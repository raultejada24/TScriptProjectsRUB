print("--- Iniciando Pruebas de Pack/Unpack ---");

# Función auxiliar para verificar resultados
function test_case(name, ta, tb, tc, td)
{
    print("Test: " + name);
    
    # 1. Empaquetar
    var packed_val = pack(ta, tb, tc, td);
    print("   > Valor empaquetado (int): " + packed_val);
    
    # 2. Desempaquetar
    var result_array = unpack(packed_val);
    var ra = result_array[0];
    var rb = result_array[1];
    var rc = result_array[2];
    var rd = result_array[3];
    
    # 3. Comparar
    if (ra == ta and rb == tb and rc == tc and rd == td) then {
        print("   ✅ ÉXITO: " + result_array);
    } else {
        print("   ❌ FALLO: Se esperaba [" + ta + ", " + tb + ", " + tc + ", " + td + "]");
        print("             Pero se recibió " + result_array);
    }
    print("--------------------------------------------");
}

# --- EJECUTAR PRUEBAS ---

# 1. Prueba Estándar (Valores intermedios)
test_case("Valores Normales", 5, 100, 5000, 6);

# 2. Prueba de Límites Mínimos (Todos 1)
test_case("Límites Mínimos", 1, 1, 1, 1);

# 3. Prueba de Límites Máximos
# a=16, b=200, c=20000, d=12
test_case("Límites Máximos", 16, 200, 20000, 12);

# 4. Prueba de Integridad (Comprobar que no se mezclan los bits)
# Usamos valores que tienen patrones de bits alternados para ver si se solapan
test_case("Patrón de Bits", 10, 170, 10922, 10);


