# -------------------------------------------------------------
# CLASE BASE: GameObject
# -------------------------------------------------------------
class GameObject {

    public: static var s_objects = [];

    protected:
    var m_x;
    var m_y;
    var m_visible;

    protected: function isNumber(x) {
        return Type(x) == Integer or Type(x) == Real;
    }

    protected: constructor(x, y) {
        if not isNumber(x) then throw "Parameter x must be a number.";
        if not isNumber(y) then throw "Parameter y must be a number.";

        m_x = x;
        m_y = y;
        m_visible = true;

        # Auto-registro
        GameObject.s_objects.push(this);
    }

    public: function toggleVisibility() {
        m_visible = not m_visible;
    }

    # --- CORRECCIÓN IMPORTANTE ---
    # Necesitamos una función PÚBLICA para consultar la visibilidad desde fuera.
    public: function isVisible() {
        return m_visible;
    }

    public: function update() {
        if (m_visible) then {
            this.draw(); 
        }
    }

    public: function draw() {}
    
    public: function getTypeString() { return "GameObject"; }
}

# -------------------------------------------------------------
# SUBCLASE: STONE
# -------------------------------------------------------------
class Stone : GameObject {
    private:
    var m_size;

    public: constructor(x, y, size) : super(x, y) {
        if not isNumber(size) then throw "Parameter size must be a number.";
        m_size = size;
    }

    public: function draw() {
        canvas.setFillColor(0.4, 0.4, 0.4);
        canvas.fillCircle(m_x, m_y, m_size);
    }
    
    public: function getTypeString() { return "Stone"; }
}

# -------------------------------------------------------------
# SUBCLASE: PERSON
# -------------------------------------------------------------
class Person : GameObject {
    private:
    var m_velocity_x;
    var m_name;

    public: constructor(x, y, vel_x, name) : super(x, y) {
        if not isNumber(vel_x) then throw "Parameter vel_x must be a number.";
        m_velocity_x = vel_x;
        m_name = name;
    }

    public: function move() {
        m_x += m_velocity_x;
    }

    public: function draw() {
        canvas.setFillColor(1, 1, 0);
        canvas.fillCircle(m_x, m_y, 20);
        canvas.setFillColor(0, 1, 1);
        canvas.fillRect(m_x - 15, m_y + 20, 30, 50);
        canvas.setFillColor(0, 0, 0);
        canvas.text(m_x, m_y - 30, m_name);
    }

    public: function update() {
        this.move();
        super.update();
    }
    
    public: function getTypeString() { return "Person (" + m_name + ")"; }
}

# -------------------------------------------------------------
# PARTE J: CREATIVIDAD (UFO)
# -------------------------------------------------------------
class UFO : GameObject {
    
    private: 
    var m_angle = 0;
    var m_startY;

    public: constructor(x, y) : super(x, y) {
        m_startY = y;
    }

    public: function draw() {
        canvas.setFillColor(0, 1, 0); 
        canvas.fillCircle(m_x, m_y, 25);
        canvas.setFillColor(0.5, 0, 0.5); 
        canvas.fillCircle(m_x, m_y - 10, 15);
    }

    public: function move() {
        m_x += 2;
        m_angle += 0.2;
        m_y = m_startY + math.sin(m_angle) * 30;
        if (m_x > canvas.width()) then m_x = 0;
    }

    public: function update() {
        this.move();
        super.update();
    }
    
    public: function getTypeString() { return "UFO"; }
}

