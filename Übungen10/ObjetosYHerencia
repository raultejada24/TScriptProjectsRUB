# EVENT HANDLERS
# -------------------------------------------------------------

setEventHandler("timer", function(event){
    canvas.setFillColor(1, 1, 1);
    canvas.clear();

    for var obj in GameObject.s_objects do {
        obj.update();
    }
});

setEventHandler("canvas.keydown", function(event){
    
    # --- LOGS PARA VISIBILIDAD ---
    if (event.key >= "0" and event.key <= "9") then {
        var index = Integer(event.key);
        if (index < GameObject.s_objects.size()) then {
            var obj = GameObject.s_objects[index];
            obj.toggleVisibility();
            
            # CORRECCIÓN: Usamos la función pública isVisible() en vez de acceder a m_visible
            var status = "HIDDEN";
            if (obj.isVisible()) then status = "VISIBLE";
            
            print("[ACTION] Toggled Object " + index + " (" + obj.getTypeString() + ") -> Now " + status);
        } else {
            print("[ERROR] Object " + index + " does not exist yet!");
        }
    }

    # --- LOGS PARA CREAR OBJETOS ---
    if (event.key == "n") then {
        var r = math.random();
        var rx = math.random() * canvas.width();
        var ry = 100 + math.random() * 300;
        
        var newObj = null;

        if (r < 0.33) then {
            newObj = Person(rx, ry, (math.random()-0.5)*4, "Random Guy");
        } else if (r < 0.66) then {
            newObj = Stone(rx, ry, 10 + math.random() * 20);
        } else {
            newObj = UFO(0, 100);
        }
        
        var currentCount = GameObject.s_objects.size();
        var newIndex = currentCount - 1; 
        
        print("[ACTION] Created new " + newObj.getTypeString() + " at index [" + newIndex + "]");
    }
});

