myStack.push(40); 
# Current: Top [40, 30, 20, 10] Bottom
myStack.print_stack();

print("Creating reversed stack...");
var reversedStack = myStack.reverse();
# Expected Reversed: Top [10, 20, 30, 40] Bottom

print("Reversed Stack:");
reversedStack.print_stack();

print("Original Stack (should be unchanged):");
myStack.print_stack();