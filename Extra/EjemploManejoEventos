canvas.setFillColor(0, 0, 0);
canvas.clear();
var w = canvas.width();
var h = canvas.height();
var s = math.min(w, h);
var k = 0;

setEventHandler("timer", function(event)
{
	var angle = k / 50;
	var radius = math.exp(k/500) * s / 18;
	var x = w/2 + radius * math.cos(angle);
	var y = h/2 + radius * math.sin(angle);
	canvas.setFillColor(1-k/1000, 1, k/1000);
	canvas.fillCircle(x, y, radius / 10);
	k += 1;
	if k == 1000 then quitEventMode();
});

enterEventMode();