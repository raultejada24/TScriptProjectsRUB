## Ejemplo Bucles recursivo (Aufgabe: Umwandlung in Rekursion (Tema 7))
function rec(i, j)
{
	print(i + " * " + j + " = " + (i*j));
	if j < i then rec(i, j+1);
	else if i < 5 then rec(i+1, 1);
}
rec(1, 1);

## Iterar en array por posiciones 0,1,2,..
var a = [16, true, "hello"];
function printvalues_(a)
{
    if Type(a) == Array
    then for var e in 0:a.size() do printvalues_(a[e]); 
    else print(a);
}
printvalues_(a);

