## Ejemplo Bucles recursivo (Aufgabe: Umwandlung in Rekursion (Tema 7))
function rec(i, j)
{
	print(i + " * " + j + " = " + (i*j));
	if j < i then rec(i, j+1);
	else if i < 5 then rec(i+1, 1);
}
rec(1, 1);

