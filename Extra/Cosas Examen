## Ordenar un Dictionary
var miDiccionario = {"bananas": 10, "manzanas": 5, "peras": 20};

# 1. Coger las keys
var llaves = miDiccionario.keys(); # ["bananas", "manzanas", "peras"]

# 2. Ordenar ese array
llaves.sort(); # Ahora es ["bananas", "manzanas", "peras"] (o alfabético inverso según quieras)

# 3. Iterar el array ordenado
for var k in llaves do
{
    #Aquí está el truco: usas 'k' (la llave), no el array entero
    var valor = miDiccionario[k]; 
    print(k + " -> " + valor);
}

