# Anonymous function for mouse down
setEventHandler("canvas.mousedown", function(event) {
    # 1. Random Radius between 4 and 10
    # math.random() gives 0 to 1. 
    # 6 * random gives 0 to 6. 
    # + 4 gives 4 to 10.
    var radius = 4 + math.random() * 6;

    # 2. Random Color
    var r = math.random();
    var g = math.random();
    var b = math.random();
    canvas.setFillColor(r, g, b);

    # 3. Draw Circle at mouse position
    canvas.fillCircle(event.x, event.y, radius);
});

