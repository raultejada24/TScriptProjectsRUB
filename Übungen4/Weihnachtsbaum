#*
   THEORY ANSWERS:
   
   1. Which data structure is best for ONE ball/snowflake?
      -> A Class (or an Object). 
      It allows us to bundle properties like x, y, speed, and radius together.
   
   2. Which data structure is best for ALL balls?
      -> An Array (List).
      It allows us to iterate through all of them to update their positions.
*#

# Implementation of Snowfall using a Class

class Snowflake {
    public:
    var x;
    var y;
    var speed;
    var size;

    constructor(w, h) {
        # Start at random X, and random Y (often above screen)
        x = math.random() * w;
        y = math.random() * h; 
        speed = 1 + math.random() * 2; # Speed between 1 and 3
        size = 2 + math.random() * 3;
    }

    function move(h) {
        y = y + speed;
        # If it goes off the bottom, reset to top
        if (y > h) then {
            y = 0;
            x = math.random() * canvas.width();
        }
    }

    function draw() {
        canvas.fillCircle(x, y, size);
    }
}

# Create an array to hold the snowflakes
var snowflakes = [];
# Create 50 snowflakes
for var k in 0:50 do {
	var c = Snowflake(w, h);
    snowflakes.push(c);
}

# Timer event to animate the snow
setEventHandler("timer", function(event) {
    # We don't want to clear the WHOLE treeq, but for simple animation
    # we usually clear screen. Since we can't redraw the tree every frame
    # easily without complex code, we will just draw white snow on top.
    
    canvas.setFillColor(1, 1, 1); # White snow
    
    for var flake in snowflakes do {
        flake.draw();
        flake.move(h);
    }
});


# Essential: Enter event mode to listen for keys, mouse, and timer
