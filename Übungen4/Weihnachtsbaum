# Function to draw a single triangle
function drawTriangle(x, y, height, width) {
    var topPoint = [x, y - height];
    var bottomRight = [x + width / 2, y];
    var bottomLeft = [x - width / 2, y];
    var points = [topPoint, bottomRight, bottomLeft];
    canvas.fillArea(points);
}

# Setup Canvas
canvas.clear();
var w = canvas.width();
var h = canvas.height();
var centerX = w / 2;

# Draw Trunk
canvas.setFillColor(0.4, 0.2, 0); 
var trunkWidth = 100;
var trunkHeight = 70;
canvas.fillRect(centerX - trunkWidth/2, h - 50 - trunkHeight, trunkWidth, trunkHeight);

# ==========================================================
# PART C: Recursive Solution
# ==========================================================

# We define global variables to track the state across recursive calls
# (Position and size of the current tree layer)
var currentY = h - 50 - trunkHeight; 
var currentWidth = 300;              
var triangleHeight = 100;

canvas.setFillColor(0, 0.5, 0); # Green for leaves

# Recursive function definition
function drawTree(i) {
    # 1. Base Case: If i is 0, stop recursion
    if (i <= 0) then return;

    # 2. Draw the triangle
    drawTriangle(centerX, currentY, triangleHeight, currentWidth);
    
    # 3. Update state for the next layer (move up and shrink)
    currentY = currentY - (triangleHeight * 0.7); 
    currentWidth = currentWidth * 0.7; 
    
    # 4. Wait to make the drawing process visible (animation)
    wait(0.5); # waits 0.5 seconds

    # 5. Recursive Step: Call the function again with i-1
    drawTree(i - 1);
}

# Execute the recursive function to draw 5 layers
# Uncomment the line below to run Part C
drawTree(5);


# ==========================================================
# PART D: Draw in Reverse
# ==========================================================
#* To draw the tree in reverse order (execution wise), 
   we swap the drawing command and the recursive call.
   
   Note: In graphics, this changes the "Painter's Algorithm" order.
   If we draw the top first, the bottom layers will overlap it.
*#

#*
function drawTreeReverse(i) {
    if (i <= 0) return;

    # We calculate the NEXT state before recursing 
    var myY = currentY; 
    var myH = triangleHeight;
    var myW = currentWidth;
    
    # Update globals for the next guy
    currentY = currentY - (triangleHeight * 0.7); 
    currentWidth = currentWidth * 0.7; 

    # RECURSIVE CALL FIRST
    drawTreeReverse(i - 1);
    
    # DRAW AFTER
    wait(0.5);
    drawTriangle(centerX, myY, myH, myW);
}
