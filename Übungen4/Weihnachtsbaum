# Anonymous function to handle key presses
setEventHandler("canvas.keydown", function(event) {
    # Check if the key pressed is "q"
    if (event.key == "q") then {
        print("Exiting Event Mode...");
        quitEventMode(); # Standard TScript command to stop events
    }
});

