class Student
{
public:
    constructor(firstname_, lastname_, id_)
    {
        firstname = firstname_;
        lastname = lastname_;
        id = id_;
    }
    var firstname;
    var lastname;
    var id;
};

function sort(students)
{
    # Usamos students.sort pasando una función anónima de comparación
    students.sort(function(a, b) {
        
        # 1. Primer criterio: Apellido (lastname)
        if (a.lastname < b.lastname) return -1;
        if (a.lastname > b.lastname) return 1;
        
        # Si no se devolvió nada, los apellidos son iguales.
        # 2. Segundo criterio: Nombre (firstname)
        if (a.firstname < b.firstname) return -1;
        if (a.firstname > b.firstname) return 1;
        
        # Si llegamos aquí, nombre y apellido son iguales.
        # 3. Tercer criterio: ID (matrikelnummer) ascendente
        if (a.id < b.id) return -1;
        if (a.id > b.id) return 1;
        
        # Son idénticos
        return 0;
    });

    return students;
    
}



