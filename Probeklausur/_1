# Esta es la funcion de comparacion auxiliar
function compareStudents(a, b)
{
    # 1. Comparar Apellidos
    if a.lastname < b.lastname then return -1;
    if a.lastname > b.lastname then return 1;

    # Si llegamos aqui, los apellidos son iguales.
    # 2. Comparar Nombres
    if a.firstname < b.firstname then return -1;
    if a.firstname > b.firstname then return 1;

    # Si llegamos aqui, nombres y apellidos son iguales.
    # 3. Comparar ID (Matrikelnummer)
    if a.id < b.id then return -1;
    else return 1;
}

# Esta es la funcion principal que pide el ejercicio
function sort(students)
{
    # Pasamos la funcion compareStudents como parametro (sin parentesis)
    students.sort(compareStudents);
    return students;
}