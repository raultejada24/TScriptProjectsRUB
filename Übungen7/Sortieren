# Función auxiliar para barajar (dada por el ejercicio)
function shuffleArraySlice(array, begin, end)
{
    for var i in begin:end do
    {
        # Genera índice aleatorio
        var j = begin + Integer((i - begin + 1) * math.random());
        
        # Intercambio (swap)
        var temp = array[i];
        array[i] = array[j];
        array[j] = temp;
    }
}

# Algoritmo de ordenamiento "Naive Random Sort"
function randomSort(a) {
    var n = a.size(); 
    var k = n;

    # Mientras queden elementos por ordenar (desde el final hacia el principio)
    while k > 0 do {
        
        # 1. Encontrar el máximo actual en el rango 0:k
        var m = a[0];
        for var i in 0:k do {
            if a[i] > m then m = a[i];
        }

        # 2. Bucle: Barajar hasta que el máximo 'm' esté en la posición k-1
        # La condición es: mientras a[k-1] sea MENOR que m, sigue barajando.
        while a[k-1] < m do {
            shuffleArraySlice(a, 0, k);
        }

        # Una vez el máximo está colocado al final del rango (en k-1), reducimos el rango
        k = k - 1;
    }
    return a;
}

