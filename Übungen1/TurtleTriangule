var a = 25;
var b = 40;

# Calculate hypotenuse
var c = math.sqrt(a*a + b*b);

# From radians to degrees
var beta = math.asin(b/c) * (180 / math.pi());
var alpha = math.asin(a/c) * (180 / math.pi());

print("a: " + a);
print("b: " + b);
print("c: " + c);
print("alpha: " + alpha);
print("beta: " + beta);

